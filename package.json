{
  "name": "agentchannels",
  "version": "0.1.5",
  "description": "Connect Claude Managed Agents to messaging channels like Slack, Discord, Teams, and more",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "ach": "dist/cli/index.js",
    "agentchannels": "dist/cli/index.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    "skills",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build",
    "dev": "tsx --watch src/cli/index.ts",
    "start": "node dist/cli/index.js serve",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bump": "node scripts/bump-version.mjs"
  },
  "keywords": [
    "claude",
    "slack",
    "agent",
    "chatbot",
    "managed-agents",
    "anthropic",
    "cli"
  ],
  "author": "AgentChannels",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentchannels/agentchannels.git"
  },
  "homepage": "https://github.com/agentchannels/agentchannels",
  "bugs": {
    "url": "https://github.com/agentchannels/agentchannels/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.7.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@inquirer/prompts": "^8.4.1",
    "@slack/bolt": "^4.7.0",
    "@slack/web-api": "^7.15.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@slack/types": "^2.20.1",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
